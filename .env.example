# ============================================================
# Environment variables for multiagent-entropy
# Copy this file to .env and fill in the values you need.
# ============================================================

# ------------------------------------------------------------
# HuggingFace
# Required to download gated model weights or private datasets.
# Get your token at https://huggingface.co/settings/tokens
# ------------------------------------------------------------
HF_TOKEN=

# ------------------------------------------------------------
# Web Search APIs  (FinAgent + GAIA benchmarks)
# At least one of SerpAPI or Serper must be set when running
# FinAgent or GAIA experiments.  SerpAPI is tried first; Serper
# is used as fallback if SerpAPI is unavailable or not set.
#
# SerpAPI:  https://serpapi.com
# Serper:   https://serper.dev
# ------------------------------------------------------------
SERPAPI_API_KEY=
SERPER_API_KEY=

# ------------------------------------------------------------
# SEC EDGAR API  (FinAgent benchmark only)
# Required for EDGAR company/filing searches in financial tasks.
# Get your key at https://sec-api.io
# Optional: if unset, EDGAR search falls back to mock results.
# ------------------------------------------------------------
SEC_EDGAR_API_KEY=

# ------------------------------------------------------------
# ByteDance ARK / Doubao API  (GAIA benchmark only)
# Required for multimodal file analysis (image / audio / video
# attachments) in GAIA tasks.  Text-only GAIA tasks still work
# without this key.
# Platform: https://www.volcengine.com/product/ark
# ------------------------------------------------------------
ARK_API_KEY=
